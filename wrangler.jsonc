{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gutmans-insurance-website",
  "compatibility_date": "2026-04-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "routes": [
    { "pattern": "gutmansinsurance.com", "custom_domain": true },
    { "pattern": "www.gutmansinsurance.com", "custom_domain": true }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
